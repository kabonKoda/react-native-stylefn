{
  "name": "react-native-stylefn",
  "version": "0.9.14",
  "description": "A Tailwind-inspired styling library that injects design tokens into every React Native component's style props automatically",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./auto": {
      "source": "./src/auto.ts",
      "types": "./lib/typescript/src/auto.d.ts",
      "default": "./lib/module/auto.js"
    },
    "./babel-plugin": "./babel-plugin/index.js",
    "./jsx-runtime": {
      "types": "./jsx-runtime/index.d.ts",
      "default": "./jsx-runtime/index.js"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx-dev-runtime/index.d.ts",
      "default": "./jsx-dev-runtime/index.js"
    },
    "./metro-config": "./metro-config/index.js",
    "./stylefn": {
      "types": "./stylefn.d.ts"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "stylefn": [
        "./stylefn.d.ts"
      ]
    }
  },
  "files": [
    "src",
    "lib",
    "babel-plugin",
    "jsx-runtime",
    "jsx-dev-runtime",
    "metro-config",
    "scripts",
    "stylefn.d.ts",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-stylefn-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "release": "release-it --only-version",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "postinstall": "node scripts/setup.js",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "react-native",
    "style",
    "styling",
    "design-tokens",
    "tailwind",
    "dark-mode",
    "responsive",
    "breakpoints",
    "theme",
    "babel-plugin",
    "typescript",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kabonKoda/react-native-stylefn.git"
  },
  "author": "Adeyeye Oluwatobiloba <adeydami8624@gmail.com> (https://github.com/kabonKoda)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kabonKoda/react-native-stylefn/issues"
  },
  "homepage": "https://github.com/kabonKoda/react-native-stylefn#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "lefthook": "^2.0.3",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.13",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "expo-device": "*"
  },
  "peerDependenciesMeta": {
    "expo-device": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "lefthook",
      "release-it",
      "eslint",
      "jest"
    ],
    "version": "0.57.2"
  }
}
